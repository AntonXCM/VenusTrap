from discord import app_commands
import discord

LANGUAGE_CSV = "language.csv"
table: dict[str, dict[str, str]] = {}

class Translator(app_commands.Translator):
    async def translate(string: app_commands.locale_str, locale: discord.Locale, context: app_commands.TranslationContext) -> str | None:
        return tr(string, locale)

def load():
    global table
    with open(LANGUAGE_CSV, encoding="utf-8-sig", newline="") as f:
        header = f.readline().split('\t')
        header[-1] = header[-1].strip()
        line = f.readline()
        while line:
            strings = line.split('\t')
            row = {}
            for i in range(1,len(strings)):
                row[header[i]] = strings[i].strip().replace('\\n', '\n')
            table[strings[0]] = row
            line = f.readline()

def tr(key: str, locale: discord.Locale) -> str:
    entry = table.get(key)
    if entry is None:
        return key
    return(entry.get(locale.language_code)
		or entry.get("en")
		or key)

load()
print(tr("hello1", discord.Locale.british_english))
